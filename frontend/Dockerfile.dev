# 개발용: 의존성만 이미지에 넣고, 소스는 볼륨 마운트 + vite dev 서버
FROM node:22-alpine
WORKDIR /app
COPY docker-dev-entrypoint.sh /usr/local/bin/docker-dev-entrypoint.sh
# Windows 체크아웃(CRLF) 시 exec 실패 방지
RUN tr -d '\r' < /usr/local/bin/docker-dev-entrypoint.sh > /tmp/docker-dev-entrypoint.sh \
  && mv /tmp/docker-dev-entrypoint.sh /usr/local/bin/docker-dev-entrypoint.sh \
  && chmod +x /usr/local/bin/docker-dev-entrypoint.sh
COPY package.json package-lock.json ./
RUN npm install
EXPOSE 5173
ENTRYPOINT ["/usr/local/bin/docker-dev-entrypoint.sh"]
