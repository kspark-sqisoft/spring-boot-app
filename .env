# 선택: docker compose 에서 오버라이드할 변수 (복사 후 .env 로 저장 가능)
DB_USERNAME=board
DB_PASSWORD=board
DB_NAME=board

# 반드시 운영에서는 강한 랜덤 문자열(UTF-8 기준 32바이트 이상)로 교체
JWT_ACCESS_SECRET=study_board_jwt_access_dev_key_32chars_min!!

JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7
REFRESH_COOKIE_SECURE=false

# 브라우저에서 쿠키+자격증명을 쓰므로 구체 출처 나열 (쉼표 구분)
# 비우면 백엔드 기본값(로컬 개발용 Origin 목록) 사용
CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080
